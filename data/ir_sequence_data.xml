<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        noupdate="1" ensures that if the user changes the prefix, padding or
        number_next from the UI, those changes will NOT be overwritten when
        the module is upgraded. The record is only created once (on first install).
    -->
    <data noupdate="1">

        <record id="seq_product_auto_default" model="ir.sequence">
            <field name="name">Configuración Global de Referencias</field>
            <field name="code">product.auto.ref.default</field>
            <field name="prefix">PROD</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="number_next">1</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
