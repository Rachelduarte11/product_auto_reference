<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ────────────────────────────────────────────────
             Action: open ir.sequence list filtered to show
             only sequences relevant to product references.
             (no domain filter → user can see/create any seq)
        ──────────────────────────────────────────────────── -->
        <record id="action_product_sequences" model="ir.actions.act_window">
            <field name="name">Secuencias de Productos</field>
            <field name="res_model">ir.sequence</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[
                ('code', '=like', 'product.auto.ref%'),
                '|',
                    ('company_id', '=', allowed_company_ids[0]),
                    ('company_id', '=', False)
            ]</field>
            <field name="context">{
                'default_code': 'product.auto.ref.',
                'default_company_id': allowed_company_ids[0]
            }</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No hay secuencias configuradas para esta compañía.
                </p>
                <p>
                    Cree una secuencia con código <b>product.auto.ref.default</b>
                    (o el código de una categoría) y asígnela a esta compañía para
                    tener un contador independiente por empresa.
                </p>
            </field>
        </record>

        <!-- ────────────────────────────────────────────────
             Menu item: Inventory > Configuration > Secuencias de Productos
        ──────────────────────────────────────────────────── -->
        <menuitem
            id="menu_product_sequences"
            name="Secuencias de Productos"
            parent="stock.menu_stock_config_settings"
            action="action_product_sequences"
            sequence="100"/>

    </data>
</odoo>
